.container {
  padding: 20rpx;
  max-width: 600rpx;
  margin: 0 auto;
}

.header {
  text-align: center;
  padding: 30rpx 0 40rpx;
}

.title {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  color: #666;
  margin-top: 12rpx;
  display: block;
}

.upload-area {
  background: #f5f5f5;
  border: 2rpx dashed #ccc;
  border-radius: 20rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
  transition: all 0.3s;
}

.upload-area:hover {
  border-color: #667eea;
  background: rgba(102,126,234,0.05);
}

.upload-icon {
  font-size: 64rpx;
  color: #999;
  display: block;
}

.upload-text {
  font-size: 26rpx;
  color: #666;
  margin-top: 20rpx;
  display: block;
}

.upload-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

.preview-image {
  width: 100%;
  max-height: 600rpx;
  border-radius: 15rpx;
}

.action-section {
  margin: 30rpx 0;
}

.tool-desc {
  background: rgba(255,250,205,0.5);
  border-left: 4rpx solid #ffd700;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.tool-desc text {
  font-size: 24rpx;
  color: #666;
  display: block;
}

.action-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 32rpx;
  border-radius: 16rpx;
  text-align: center;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  transition: transform 0.2s;
}

.action-btn:active {
  transform: scale(0.98);
}

.action-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.action-btn.save {
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
}

.action-btn.reset {
  background: #f0f0f0;
  color: #666;
  font-size: 28rpx;
}

.result-section {
  margin-top: 40rpx;
  padding: 30rpx;
  background: #f9f9f9;
  border-radius: 20rpx;
}

.result-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.result-title {
  font-size: 32rpx;
  color: #667eea;
  font-weight: bold;
  display: block;
}

.compare-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.image-compare {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.compare-item {
  flex: 1;
}

.compare-item text.label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
  text-align: center;
}

.compare-item image {
  width: 100%;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
}
