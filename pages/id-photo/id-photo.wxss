.container {
  padding: 20rpx;
  max-width: 600rpx;
  margin: 0 auto;
}

.header {
  text-align: center;
  padding: 30rpx 0 40rpx;
}

.title {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  color: #666;
  margin-top: 12rpx;
  display: block;
}

.upload-area {
  background: #f5f5f5;
  border: 2rpx dashed #ccc;
  border-radius: 20rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
}

.upload-icon {
  font-size: 64rpx;
  color: #999;
  display: block;
}

.upload-text {
  font-size: 26rpx;
  color: #999;
  margin-top: 20rpx;
  display: block;
}

.preview-image {
  width: 100%;
  max-height: 600rpx;
  border-radius: 15rpx;
}

.color-selector {
  background: #f9f9f9;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.option {
  margin-bottom: 20rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  display: block;
}

.colors {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.color-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 3rpx solid transparent;
  cursor: pointer;
}

.color-item.selected {
  border-color: #667eea;
  background: rgba(102,126,234,0.1);
}

.color-preview {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-bottom: 10rpx;
}

.color-preview.white {
  background: white;
  border: 2rpx solid #ddd;
}

.color-preview.red {
  background: #e84a5f;
}

.color-preview.blue {
  background: #3498db;
}

.color-name {
  font-size: 24rpx;
  color: #666;
}

.action-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 30rpx;
  border-radius: 15rpx;
  text-align: center;
  margin-bottom: 20rpx;
  font-size: 30rpx;
}

.action-btn.process:active {
  opacity: 0.8;
}

.action-btn.save {
  background: #52c41a;
}

.result-section {
  margin-top: 40rpx;
  padding: 30rpx;
  background: #f9f9f9;
  border-radius: 15rpx;
}

.result-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.result-image {
  width: 100%;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}
